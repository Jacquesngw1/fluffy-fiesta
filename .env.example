# Environment Variables for GEO Audit Tool
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------
# Required
# -----------------------------------------------------------------

# OpenRouter API key for querying LLMs (ChatGPT, Gemini, Perplexity)
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -----------------------------------------------------------------
# Optional
# -----------------------------------------------------------------

# Redis URL for background task queue (defaults to in-memory queue)
# REDIS_URL=redis://localhost:6379/0

# Directory where generated PDF/HTML reports are saved (default: ./reports)
# OUTPUT_DIR=./reports

# Maximum number of pages to crawl per audit (default: 50)
# MAX_PAGES=50

# Request timeout in seconds (default: 30)
# REQUEST_TIMEOUT=30

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO
